      "title": "P95 vs P99 Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(bifrost_upstream_latency_seconds_bucket[1m])) by (le))",
