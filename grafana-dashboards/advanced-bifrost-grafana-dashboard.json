      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "(sum(rate(bifrost_success_requests_total[1m])) / sum(rate(bifrost_upstream_requests_total[1m]))) * 100",
