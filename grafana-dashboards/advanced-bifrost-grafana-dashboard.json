          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(bifrost_upstream_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "B"
        },
        {
          "expr": "sum(rate(bifrost_upstream_latency_seconds_sum[1m])) / sum(rate(bifrost_upstream_latency_seconds_count[1m]))",
