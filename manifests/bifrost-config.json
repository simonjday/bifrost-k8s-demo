{
  "$schema": "https://www.getbifrost.ai/schema",
  "audit_logs": {
    "disabled": false
  },
  "client": {
    "allowed_origins": ["*"],
    "compat": {
      "convert_chat_to_responses": false,
      "convert_text_to_chat": false,
      "should_convert_params": false,
      "should_drop_params": false
    },
    "disable_content_logging": false,
    "disable_db_pings_in_health": false,
    "drop_excess_requests": false,
    "enable_logging": true,
    "enforce_auth_on_inference": true,
    "enforce_governance_header": false,
    "initial_pool_size": 300,
    "log_retention_days": 365,
    "max_request_body_size_mb": 100
  },
  "config_store": {
    "config": {
      "path": "/app/data/config.db"
    },
    "enabled": true,
    "type": "sqlite"
  },
  "framework": {
    "pricing": {
      "pricing_sync_interval": 86400,
      "pricing_url": "https://getbifrost.ai/datasheet"
    }
  },
  "logs_store": {
    "config": {
      "path": "/app/data/logs.db"
    },
    "enabled": true,
    "type": "sqlite"
  },
  "plugins": [
    {
      "name": "telemetry",
      "enabled": true
    }
  ]
}
